{
    "name": "@jaculus/common",
    "version": "0.0.1",
    "description": "Common utilities and types used across Jaculus packages",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jaculus-org/Jaculus-tools.git"
    },
    "author": {
        "name": "Petr Kubica (cubicap)"
    },
    "license": "GPL-3.0-only",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -b",
        "build:watch": "tsc -b --watch",
        "clean": "rimraf dist tsconfig.tsbuildinfo",
        "fullclean": "npm run clean && rimraf node_modules"
    },
    "devDependencies": {
        "rimraf": "^6.0.1",
        "typescript": "^5.8.3"
    }
}
