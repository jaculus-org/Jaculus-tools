{
    "name": "@jaculus/project",
    "version": "0.0.2",
    "description": "Library for managing Jaculus projects, including source files, build, and dependencies",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jaculus-org/Jaculus-tools.git"
    },
    "author": {
        "name": "Petr Kubica (cubicap)"
    },
    "license": "GPL-3.0-only",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/src/project.d.ts",
            "import": "./dist/src/project.js"
        },
        "./compiler": {
            "types": "./dist/src/compiler/index.d.ts",
            "import": "./dist/src/compiler/index.js"
        },
        "./fs": {
            "types": "./dist/src/fs.d.ts",
            "import": "./dist/src/fs.js"
        },
        "./package": {
            "types": "./dist/src/package.d.ts",
            "import": "./dist/src/package.js"
        },
        "./registry": {
            "types": "./dist/src/registry.d.ts",
            "import": "./dist/src/registry.js"
        },
        "./creation": {
            "types": "./dist/src/project-creation.d.ts",
            "import": "./dist/src/project-creation.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -b",
        "build:watch": "tsc -b --watch",
        "clean": "rimraf dist tsconfig.tsbuildinfo",
        "fullclean": "npm run clean && rimraf node_modules"
    },
    "dependencies": {
        "@jaculus/common": "workspace:*",
        "pako": "^2.1.0",
        "semver": "^7.7.3",
        "typescript": "^5.8.3",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/pako": "^2.0.4",
        "@types/semver": "^7.7.1",
        "rimraf": "^6.0.1"
    }
}
