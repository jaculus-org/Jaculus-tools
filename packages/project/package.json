{
    "name": "@jaculus/project",
    "version": "0.0.1",
    "description": "Library for managing Jaculus projects, including source files, build, and dependencies",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jaculus-org/Jaculus-tools.git"
    },
    "author": {
        "name": "Petr Kubica (cubicap)"
    },
    "license": "GPL-3.0-only",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/src/project/index.d.ts",
            "import": "./dist/src/project/index.js"
        },
        "./compiler": {
            "types": "./dist/src/compiler/index.d.ts",
            "import": "./dist/src/compiler/index.js"
        },
        "./fs": {
            "types": "./dist/src/fs/index.d.ts",
            "import": "./dist/src/fs/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -b",
        "build:watch": "tsc -b --watch",
        "clean": "rimraf dist tsconfig.tsbuildinfo",
        "fullclean": "npm run clean && rimraf node_modules",
        "test": "mocha test/**/*.test.ts"
    },
    "dependencies": {
        "@jaculus/common": "workspace:*",
        "typescript": "^5.8.3"
    },
    "devDependencies": {
        "rimraf": "^6.0.1"
    }
}
